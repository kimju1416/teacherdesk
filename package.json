{
  "name": "teacherdesk",
  "productName": "TeacherDesk",
  "version": "1.7.0",
  "description": "선생님 바탕화면 대시보드 - TeacherDesk Pro",
  "main": "main.js",
  "author": "kimju.zip",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "zip.kimju.teacherdesk",
    "productName": "TeacherDesk",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "setup.html",
      "assets/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "TeacherDesk-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "kimju1416",
        "repo": "teacherdesk"
      }
    ],
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "TeacherDesk 선생님 바탕화면"
    }
  },
  "allowScripts": {
    "electron@35.7.5": true
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
